{
  "services": [
    {
      "type": "web",
      "name": "ai-summarization-server",
      "runtime": "node",
      "plan": "free",
      "buildCommand": "npm install",
      "startCommand": "node index.js",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "PORT",
          "value": "5000"
        },
        {
          "key": "MONGODB_URI",
          "sync": false
        },
        {
          "key": "OPENAI_API_KEY",
          "sync": false
        },
        {
          "key": "JWT_SECRET",
          "sync": false
        },
        {
          "key": "CLIENT_URL",
          "value": "https://your-frontend-url.vercel.app"
        }
      ]
    }
  ]
}
